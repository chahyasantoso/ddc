{
  "name": "ddc",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/fix-wrangler.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "db:setup": "wrangler d1 execute ddc-journal --local --file=./db/schema.sql",
    "db:seed": "wrangler d1 execute ddc-journal --local --file=./db/seed.sql",
    "db:reset": "wrangler d1 execute ddc-journal --local --file=./db/reset.sql",
    "db:deploy": "wrangler d1 execute ddc-journal --remote --file=./db/schema.sql"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/react": "^5.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/multer": "^2.1.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.5",
    "better-sqlite3": "^12.8.0",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.23",
    "maplibre-gl": "^5.22.0",
    "multer": "^2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-map-gl": "^8.1.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "wrangler": "^4.81.1"
  }
}
