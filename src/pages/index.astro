---
import type { CheckpointWithPhotos, Checkpoint, Photo } from '../lib/db';
import { ScrollytellingUI } from '../components/ScrollytellingUI';
import { HeroSection } from '../components/HeroSection';
import { FooterSection } from '../components/FooterSection';
import '../styles/global.css';
import '../styles/hero.css';
import '../styles/footer.css';
import '../styles/scrollytelling.css';
import '../styles/map.css';
import '../styles/modal.css';
import '../styles/splash.css';
import 'lenis/dist/lenis.css';
import { env } from 'cloudflare:workers';

// Slim coord type for the map island (no photos = smaller JSON payload)
type MapCheckpoint = { id: number; location_name: string; lat: number; lng: number };

import { getDB } from '../lib/db-client';

// ── Server-side data fetch ────────────────────────────────────────────────
let checkpoints: CheckpointWithPhotos[] = [];
let mapCheckpoints: MapCheckpoint[] = [];

try {
  const db = await getDB(env);
  
  const { results: rawCheckpoints } = await db
    .prepare(`SELECT * FROM checkpoints ORDER BY created_at ASC`)
    .all<Checkpoint>();

  const { results: rawPhotos } = await db
    .prepare(`SELECT * FROM photos ORDER BY checkpoint_id ASC, "order" ASC`)
    .all<Photo>();

  // Assemble CheckpointWithPhotos (full data for UI island)
  checkpoints = rawCheckpoints.map((cp: Checkpoint) => {
    const allPhotos = rawPhotos
      .filter((p: Photo) => p.checkpoint_id === cp.id)
      .sort((a: Photo, b: Photo) => a.order - b.order);
      
    // Find first backdrop for DB backward compat
    const firstBackdrop = allPhotos.find((p: Photo) => p.is_backdrop === 1);
    
    return {
      ...cp,
      photos: allPhotos,
      scene_image: firstBackdrop?.photo_url ?? cp.scene_image ?? null,
    };
  });

  // Slim list for map island (smaller prop payload)
  mapCheckpoints = checkpoints.map(({ id, location_name, lat, lng }) => ({
    id,
    location_name,
    lat,
    lng,
  }));
} catch (e) {
  console.error('Failed to load data from database:', e);
}
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="DDC — Live motorcycle travel journal. Perjalanan nyata, foto nyata, peta bergerak. Ikuti perjalanan dari Surabaya."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Oswald:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>DDC — Live Motorcycle Journal</title>
  </head>

  <body>
    <!-- ── Premium Splash Screen ─────────────────────────────────────────── -->
    <div id="splash-screen">
      <div class="splash-content">
        <div class="splash-logo-container">
          <div class="splash-glow"></div>
          <div class="splash-moto">🏍️</div>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center">
          <h1 class="splash-title">DDC</h1>
          <p class="splash-tagline">Initializing Journey...</p>
        </div>
        <div class="splash-loader"></div>
      </div>
    </div>

    <HeroSection client:load />

    <!-- HUD: top bar with branding -->
    <div class="hud-bar" style="position: fixed; z-index: 10;">
      <span class="hud-live-dot"></span>
      <span class="hud-title">DDC</span>
      <span class="hud-subtitle">Live Motorcycle Journal</span>
    </div>


    <!-- ── Native Scrollytelling Content ──────────────────────────────────── -->
    <ScrollytellingUI client:only="react" checkpoints={checkpoints} mapCheckpoints={mapCheckpoints} />

    <FooterSection />

    <!-- ── Noscript fallback ───────────────────────────────────────────────── -->
    <!-- Shown ONLY when JavaScript is disabled. -->
    <noscript>
      <style>
        /* Sembunyikan UI layout bawaan JS (map dan react container) */
        .fixed-layer, .hud-bar, .native-scrolly-container { display: none !important; }
      </style>
      <div class="noscript-fallback">
        <header class="noscript-header">
          <h1 class="noscript-title">DDC</h1>
          <p class="noscript-subtitle">Live Motorcycle Journal · JavaScript required for interactive map</p>
        </header>

        {checkpoints.length === 0 && (
          <p style="color: var(--text-muted)">Belum ada checkpoint. Tambahkan via admin panel.</p>
        )}

        {checkpoints.map((cp) => (
          <article class="ns-checkpoint">
            <h2 class="ns-checkpoint-name">{cp.location_name}</h2>
            {cp.description && <p class="ns-checkpoint-desc">{cp.description}</p>}
            {cp.photos.length > 0 && (
              <div class="ns-photos">
                {cp.photos.map((photo) => (
                  <img
                    src={photo.photo_url}
                    alt={photo.caption}
                    loading="lazy"
                    decoding="async"
                  />
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </noscript>

    <script>
      import Lenis from 'lenis';

      // Initialize Lenis at the global page level
      const lenis = new Lenis({
        lerp: 0.1,
        autoRaf: true,
      });

      // Export globally so React islands can trigger jumps
      (window as any).__lenis = lenis;

      // Handle Splash Screen Removal
      window.addEventListener('ddc:ready', () => {
        const splash = document.getElementById('splash-screen');
        if (splash) {
          splash.classList.add('fade-out');
          setTimeout(() => splash.remove(), 1000);
        }
      });

      // Safety fallback: if the map fails to load within 5s, clear the splash anyway
      setTimeout(() => {
        const splash = document.getElementById('splash-screen');
        if (splash && !splash.classList.contains('fade-out')) {
          console.warn('Splash safety timeout triggered.');
          splash.classList.add('fade-out');
          setTimeout(() => splash.remove(), 1000);
        }
      }, 5000);
    </script>
  </body>
</html>
