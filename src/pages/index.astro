---
import { getDb } from '../lib/db';
import type { CheckpointWithPhotos } from '../lib/db';
import { InteractiveMap } from '../components/InteractiveMap';
import { ScrollytellingUI } from '../components/ScrollytellingUI';
import '../styles/global.css';

// Slim coord type for the map island (no photos = smaller JSON payload)
type MapCheckpoint = { id: number; location_name: string; lat: number; lng: number };

// ── Server-side data fetch ────────────────────────────────────────────────
const db = getDb();

const rawCheckpoints = db
  .prepare(`SELECT * FROM checkpoints ORDER BY created_at ASC`)
  .all() as import('../lib/db').Checkpoint[];

const rawPhotos = db
  .prepare(`SELECT * FROM photos ORDER BY checkpoint_id ASC, "order" ASC`)
  .all() as import('../lib/db').Photo[];

// Assemble CheckpointWithPhotos (full data for UI island)
const checkpoints: CheckpointWithPhotos[] = rawCheckpoints.map((cp) => ({
  ...cp,
  photos: rawPhotos.filter((p) => p.checkpoint_id === cp.id),
}));

// Slim list for map island (smaller prop payload)
const mapCheckpoints: MapCheckpoint[] = checkpoints.map(
  ({ id, location_name, lat, lng }) => ({ id, location_name, lat, lng })
);

// Ghost scroll height: each checkpoint gets 200vh of scroll real estate
const ghostHeight = `${Math.max(checkpoints.length, 1) * 200}vh`;
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="DDC — Live motorcycle travel journal. Perjalanan nyata, foto nyata, peta bergerak. Ikuti perjalanan dari Surabaya."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>DDC — Live Motorcycle Journal</title>
  </head>

  <body>
    <!-- ── Ghost scroll driver (transparent, drives window.scrollY) ──────── -->
    <div class="scroll-ghost" style={`height: ${ghostHeight}; position: relative;`}>
      {checkpoints.length > 1 && checkpoints.map((_, i) => (
        <div 
          style={`
            position: absolute; 
            top: calc(${i / (checkpoints.length - 1)} * (100% - 100vh)); 
            left: 0; 
            width: 100%; 
            height: 10px; 
            scroll-snap-align: start;
            pointer-events: none;
          `}
        ></div>
      ))}
    </div>

    <!-- ── Fixed UI layer ─────────────────────────────────────────────────── -->
    <div class="fixed-layer">

      <!-- Full-screen map (WebGL) -->
      <div class="map-fullscreen">
        <InteractiveMap client:only="react" checkpoints={mapCheckpoints} />
      </div>

      <!-- HUD: top bar with branding -->
      <div class="hud-bar">
        <span class="hud-live-dot"></span>
        <span class="hud-title">DDC</span>
        <span class="hud-subtitle">Live Motorcycle Journal</span>
      </div>

      <!-- Admin link -->
      <a href="/admin" class="admin-link-fixed">Admin ↗</a>

      <!-- Scrollytelling UI: floating photos + checkpoint info card -->
      <!-- Only mounts when checkpoints exist -->
      {checkpoints.length > 0 && (
        <ScrollytellingUI client:only="react" checkpoints={checkpoints} />
      )}

    </div><!-- /.fixed-layer -->

    <!-- ── Noscript fallback ───────────────────────────────────────────────── -->
    <!-- Shown ONLY when JavaScript is disabled. The fixed layer above is empty
         in that case (client:only components don't render server-side). -->
    <noscript>
      <div class="noscript-fallback">
        <header class="noscript-header">
          <h1 class="noscript-title">DDC</h1>
          <p class="noscript-subtitle">Live Motorcycle Journal · JavaScript required for interactive map</p>
        </header>

        {checkpoints.length === 0 && (
          <p style="color: var(--text-muted)">Belum ada checkpoint. Tambahkan via admin panel.</p>
        )}

        {checkpoints.map((cp) => (
          <article class="ns-checkpoint">
            <h2 class="ns-checkpoint-name">{cp.location_name}</h2>
            {cp.description && <p class="ns-checkpoint-desc">{cp.description}</p>}
            {cp.photos.length > 0 && (
              <div class="ns-photos">
                {cp.photos.map((photo) => (
                  <img
                    src={photo.photo_url}
                    alt={photo.caption}
                    loading="lazy"
                    decoding="async"
                  />
                ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </noscript>

    <!-- ── Scroll Sync Engine ─────────────────────────────────────────────── -->
    <!-- Tracks window.scrollY, fires ddc:scroll{ progress: 0-1 } for islands -->
    <script>
      (function () {
        let ticking = false;

        function dispatch() {
          const scrollable = document.documentElement.scrollHeight - window.innerHeight;
          if (scrollable <= 0) return;
          const progress = Math.max(0, Math.min(1, window.scrollY / scrollable));
          window.dispatchEvent(
            new CustomEvent('ddc:scroll', { detail: { progress } })
          );
          ticking = false;
        }

        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(dispatch);
            ticking = true;
          }
        }, { passive: true });

        // Fire once on load so islands start in correct state
        dispatch();
      })();
    </script>

  </body>
</html>
